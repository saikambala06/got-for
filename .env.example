# Copy this file to .env and fill in real values. Never commit the real .env.

# MongoDB connection string (Atlas or self-hosted). Required.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/skvk

# Secret used to sign session JWTs. Required — use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Gemini API key(s) that power resume parsing, tailoring, and job analysis.
# Set GEMINI_API_KEY for a single key, or GEMINI_API_KEYS as a comma-separated
# list to round-robin across multiple keys (recommended if you're hitting
# per-key rate limits). At least one is required for AI features to work.
GEMINI_API_KEY=
GEMINI_API_KEYS=

# Optional: override the Gemini model used for all AI calls. Defaults to
# "gemini-flash-latest" if unset.
GEMINI_MODEL=

# Local dev server port (Vercel ignores this in production).
PORT=4000
