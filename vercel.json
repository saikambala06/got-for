{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/resumes", "dest": "/resumes.html" },
    { "src": "/job-tracker", "dest": "/job-tracker.html" },
    { "src": "/account", "dest": "/account.html" }
  ]
}